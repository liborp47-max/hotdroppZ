# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI — Groq (free tier, required) ─────────────────────────────────────────
# Get key: console.groq.com — no credit card required
GROQ_API_KEY=gsk_your_groq_key

# ─── AI — Anthropic (optional, Claude Haiku fallback writer) ─────────────────
# Get key: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ─── Music APIs ───────────────────────────────────────────────────────────────
# Spotify — create app at developer.spotify.com
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube Data API v3 — console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key

# Genius — genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_access_token

# ─── Image APIs (all optional, stack is tried in order) ──────────────────────
# Unsplash — unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Pexels — pexels.com/api
PEXELS_API_KEY=your_pexels_api_key

# Pixabay — pixabay.com/api/docs
PIXABAY_API_KEY=your_pixabay_api_key

# ─── Pipeline Tuning ─────────────────────────────────────────────────────────
# Minimum attention_score for a cluster to be written (default: 5)
WRITER_SCORE_THRESHOLD=5

# ─── Self-hosted AI (optional, Ollama fallback) ───────────────────────────────
# Run locally: ollama serve && ollama pull mistral
OLLAMA_URL=http://localhost:11434

# ─── Cron Auth (required for Vercel cron routes) ─────────────────────────────
# Any random secret — must match the Authorization header Vercel sends
CRON_SECRET=your_random_cron_secret
