    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^0.511.0",
    "next": "15.3.1",
    "openai": "^6.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
