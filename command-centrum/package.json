{
  "name": "hdcc",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/dev-guard.mjs",
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev -H 0.0.0.0",
    "build": "next build",
    "start": "cross-env NODE_OPTIONS=--use-system-ca next start -H 0.0.0.0",
