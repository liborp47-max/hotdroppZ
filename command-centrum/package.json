    "desktop:build": "cross-env DESKTOP_BUILD=1 next build && npm run desktop:prepare-server && electron-builder",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 243",
    "lint:md": "markdownlint ../INFO/**/*.md --config ../.markdownlint.json",
    "typecheck": "tsc --noEmit",
    "test:truth-gate": "npm run test:missions && npm run test:evidence-contract && npm run test:refresh-truth && npm run test:stage-registry && npm run test:local-runner && npm run test:evidence-summary && npm run test:agent-runner && npm run test:mission-lifecycle",
